{
	"expo": {
		"name": "imeat",
		"slug": "imeat",
		"version": "1.0.0",
		"orientation": "portrait",
		"icon": "./assets/images/icon.png",
		"scheme": "imeat",
		"userInterfaceStyle": "automatic",
		"newArchEnabled": true,
		"ios": {
			"supportsTablet": true,
			"bundleIdentifier": "com.cupolo.imeat",
			"infoPlist": {
				"ITSAppUsesNonExemptEncryption": false
			}
		},
		"android": {
			"adaptiveIcon": {
				"backgroundColor": "#E6F4FE",
				"foregroundImage": "./assets/images/android-icon-foreground.png",
				"backgroundImage": "./assets/images/android-icon-background.png",
				"monochromeImage": "./assets/images/android-icon-monochrome.png"
			},
			"config": {
				"googleMaps": {
					"apiKey": "AIzaSyCoN-PmfMq4z_CZUyY_l9wddON1NyowzJE"
				}
			},
			"edgeToEdgeEnabled": true,
			"predictiveBackGestureEnabled": false,
			"package": "com.cupolo.imeat"
		},
		"web": {
			"output": "static",
			"favicon": "./assets/images/favicon.png"
		},
		"plugins": [
			"expo-router",
			[
				"expo-splash-screen",
				{
					"image": "./assets/images/splash-icon.png",
					"imageWidth": 200,
					"resizeMode": "contain",
					"backgroundColor": "#ffffff",
					"dark": {
						"backgroundColor": "#000000"
					}
				}
			],
			"expo-secure-store",
			"expo-web-browser"
		],
		"experiments": {
			"typedRoutes": true,
			"reactCompiler": true
		},
		"extra": {
			"router": {},
			"eas": {
				"projectId": "aa83a33e-f881-43d2-8731-659896f3b992"
			}
		},
		"owner": "cupolo"
	},
	"build": {
		"development": {
			"env": {
				"EXPO_PUBLIC_API_URL": "https://imeat-backend-1.onrender.com/api"
			}
		},
		"preview": {
			"env": {
				"EXPO_PUBLIC_API_URL": "https://imeat-backend.onrender.com/api"
			}
		}
	}
}
